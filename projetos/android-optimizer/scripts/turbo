#!/data/data/com.termux/files/usr/bin/bash
G='\e[0;32m';Y='\e[0;33m';R='\e[0;31m';C='\e[1;36m';W='\e[1;37m';D='\e[2;37m';BG='\e[1;32m';BY='\e[1;33m';BR='\e[1;31m';X='\e[0m'
bar(){ local v=$1 s=${2:-20} f=$((v*s/100)) e=$((s-v*s/100)) b=""; for i in $(seq 1 $f);do b="${b}█";done; for i in $(seq 1 $e);do b="${b}░";done; echo -n "$b"; }
clear
echo -e "${C}╔══════════════════════════════════════════════════╗${X}"
echo -e "${C}║${W}       🚀  REALME C55  —  MODO TURBO             ${C}║${X}"
echo -e "${C}║${D}               $(date '+%d/%m/%Y   %H:%M:%S')               ${C}║${X}"
echo -e "${C}╚══════════════════════════════════════════════════╝${X}"
echo ""
RT=$(grep MemTotal /proc/meminfo|awk '{print int($2/1024)}')
RA=$(grep MemAvailable /proc/meminfo|awk '{print int($2/1024)}')
RU=$((RT-RA)); RP=$((RU*100/RT))
echo -e "  ${W}📊 ANTES DA LIMPEZA${X}"
echo -e "  ${D}┌──────────────────────────────────────────────┐${X}"
printf "  ${D}│${X}  %-14s  ${Y}$(bar $RP)${X}  ${Y}%s%%${X}         ${D}│${X}\n" "RAM usada" "$RP"
printf "  ${D}│${X}  %-14s  ${W}%s MB em uso de %s MB${X}     ${D}│${X}\n" "Memoria" "$RU" "$RT"
echo -e "  ${D}└──────────────────────────────────────────────┘${X}"
echo ""
echo -e "  ${D}┌──────────────────────────────────────────────┐${X}"
echo -e "  ${D}│${X}  ${C}Limpando arquivos temporarios...${X}              ${D}│${X}"
CNT=0; SZ=0
while IFS= read -r -d '' f; do
  s=$(stat -c %s "$f" 2>/dev/null||echo 0)
  rm -f "$f" 2>/dev/null && CNT=$((CNT+1)) && SZ=$((SZ+s))
done < <(find /sdcard -maxdepth 4 \( -name "*.tmp" -o -name "*.log" \) -size +1M -print0 2>/dev/null)
SZM=$((SZ/1048576))
printf "  ${D}│${X}  ${G}✓${X}  Removidos: ${W}%s arquivos${X} (${G}%s MB${X})     ${D}│${X}\n" "$CNT" "$SZM"
echo -e "  ${D}│${X}                                              ${D}│${X}"
echo -e "  ${D}│${X}  ${C}Liberando cache de sistema...${X}              ${D}│${X}"
sync
echo -e "  ${D}│${X}  ${G}✓${X}  Cache de paginas sincronizado           ${D}│${X}"
echo -e "  ${D}└──────────────────────────────────────────────┘${X}"
echo ""
sleep 1
RA2=$(grep MemAvailable /proc/meminfo|awk '{print int($2/1024)}')
RU2=$((RT-RA2)); RP2=$((RU2*100/RT))
GANHO=$((RA2-RA))
echo -e "  ${W}📊 DEPOIS DA LIMPEZA${X}"
echo -e "  ${D}┌──────────────────────────────────────────────┐${X}"
printf "  ${D}│${X}  %-14s  ${G}$(bar $RP2)${X}  ${G}%s%%${X}         ${D}│${X}\n" "RAM usada" "$RP2"
printf "  ${D}│${X}  %-14s  ${G}%s MB livres de %s MB${X}   ${D}│${X}\n" "Memoria" "$RA2" "$RT"
echo -e "  ${D}└──────────────────────────────────────────────┘${X}"
echo ""
[ $GANHO -gt 0 ] && PD="+ ${GANHO} MB liberados na RAM" || PD="RAM sem alteracao"
echo -e "  ${C}╔══════════════════════════════════════════════╗${X}"
printf "  ${C}║  ${G}  %-44s${C}║${X}\n" "$PD"
[ $SZM -gt 0 ] && printf "  ${C}║  ${G}  %-44s${C}║${X}\n" "+ ${SZM} MB em tmp/log removidos"
echo -e "  ${C}╚══════════════════════════════════════════════╝${X}"
echo ""
[ $GANHO -gt 0 ] || [ $SZM -gt 0 ] && echo -e "  ${G}  ✓  Turbo concluido com sucesso${X}" || echo -e "  ${Y}  ○  Sistema ja estava otimizado${X}"
echo ""
