---
const base = '/portfolio-dados';
const links = [
  { href: `${base}/`, label: 'Home' },
  { href: `${base}/sobre`, label: 'Sobre' },
  { href: `${base}/stacks`, label: 'Stacks' },
  { href: `${base}/projetos`, label: 'Projetos' },
  { href: `${base}/estudos`, label: 'Estudos' },
  { href: `${base}/biblioteca`, label: 'Biblioteca' },
];

const current = Astro.url.pathname;
---

<nav class="nav">
  <div class="nav-inner container">
    <a href={`${base}/`} class="nav-logo">
      <span class="logo-text">OS</span>
      <span class="logo-label">/ data</span>
    </a>

    <div class="nav-links">
      {links.map(l => (
        <a
          href={l.href}
          class={`nav-link ${current === l.href || (l.href !== `${base}/` && current.startsWith(l.href)) ? 'active' : ''}`}
        >
          {l.label}
        </a>
      ))}
    </div>

    <a
      href="https://github.com/Odiney-SP"
      target="_blank"
      rel="noopener"
      class="nav-github btn btn-ghost"
      aria-label="GitHub"
    >
      <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor">
        <path d="M12 2C6.477 2 2 6.484 2 12.017c0 4.425 2.865 8.18 6.839 9.504.5.092.682-.217.682-.483 0-.237-.008-.868-.013-1.703-2.782.605-3.369-1.343-3.369-1.343-.454-1.158-1.11-1.466-1.11-1.466-.908-.62.069-.608.069-.608 1.003.07 1.531 1.032 1.531 1.032.892 1.53 2.341 1.088 2.91.832.092-.647.35-1.088.636-1.338-2.22-.253-4.555-1.113-4.555-4.951 0-1.093.39-1.988 1.029-2.688-.103-.253-.446-1.272.098-2.65 0 0 .84-.27 2.75 1.026A9.564 9.564 0 0112 6.844c.85.004 1.705.115 2.504.337 1.909-1.296 2.747-1.027 2.747-1.027.546 1.379.202 2.398.1 2.651.64.7 1.028 1.595 1.028 2.688 0 3.848-2.339 4.695-4.566 4.943.359.309.678.92.678 1.855 0 1.338-.012 2.419-.012 2.747 0 .268.18.58.688.482A10.019 10.019 0 0022 12.017C22 6.484 17.522 2 12 2z"/>
      </svg>
      GitHub
    </a>
  </div>
</nav>

<style>
.nav {
  position: sticky;
  top: 0;
  z-index: 50;
  height: var(--nav-h);
  border-bottom: 1px solid var(--border);
  background: rgba(10, 10, 10, .85);
  backdrop-filter: blur(12px);
  -webkit-backdrop-filter: blur(12px);
}

.nav-inner {
  height: 100%;
  display: flex;
  align-items: center;
  gap: 2rem;
}

.nav-logo {
  display: flex;
  align-items: center;
  gap: .35rem;
  text-decoration: none;
  flex-shrink: 0;
}

.logo-text {
  font-family: var(--font-mono);
  font-size: .9rem;
  font-weight: 500;
  color: var(--text);
  background: var(--gradient);
  -webkit-background-clip: text;
  -webkit-text-fill-color: transparent;
  background-clip: text;
}

.logo-label {
  font-family: var(--font-mono);
  font-size: .8rem;
  color: var(--text-muted);
}

.nav-links {
  display: flex;
  align-items: center;
  gap: .25rem;
  flex: 1;
}

.nav-link {
  padding: .35rem .65rem;
  border-radius: 6px;
  font-size: .85rem;
  color: var(--text-muted);
  text-decoration: none;
  transition: color .15s, background .15s;
}

.nav-link:hover { color: var(--text); background: var(--bg-hover); }
.nav-link.active { color: var(--text); }

.nav-github {
  margin-left: auto;
  flex-shrink: 0;
  font-size: .8rem;
}

@media (max-width: 700px) {
  .nav-links { display: none; }
  .nav-github { margin-left: auto; }
}
</style>
