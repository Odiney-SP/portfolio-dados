---
import Base from '@/layouts/Base.astro';

const base = '/portfolio-dados';

const stacks = [
  {
    id: 'sql',
    name: 'SQL',
    icon: '⬡',
    level: 65,
    levelLabel: 'intermediário',
    color: 'blue',
    desc: 'Linguagem principal para análise de dados. Foco em consultas analíticas sobre dados operacionais.',
    skills: [
      'SELECT, JOINs, GROUP BY, filtros',
      'CTEs (Common Table Expressions)',
      'Window Functions (ROW_NUMBER, RANK, LAG/LEAD)',
      'Subqueries e agregações compostas',
      'Análise de séries temporais com SQL',
      'Queries para indicadores de produtividade e SLA',
    ],
    resources: ['PostgreSQL', 'SQLite', 'Mode Analytics', 'DataCamp SQL track'],
    ghLink: `${base}/estudos`,
  },
  {
    id: 'python',
    name: 'Python',
    icon: '⬢',
    level: 45,
    levelLabel: 'básico-intermediário',
    color: 'purple',
    desc: 'Para automação, manipulação de dados e (futuramente) ML. Pandas é o foco atual.',
    skills: [
      'Sintaxe básica, listas, dicionários, loops',
      'Funções e controle de fluxo',
      'Pandas: leitura, limpeza, transformação',
      'Cruzamento e agregação de DataFrames',
      'Visualização com Matplotlib e Seaborn',
      'Automação de arquivos e relatórios',
    ],
    resources: ['Alura Python', 'DataCamp Pandas', 'Documentação oficial', 'Kaggle'],
    ghLink: `${base}/estudos`,
  },
  {
    id: 'powerbi',
    name: 'Power BI',
    icon: '◈',
    level: 55,
    levelLabel: 'intermediário',
    color: 'blue',
    desc: 'Ferramenta principal para dashboards gerenciais. Modelagem e DAX são o diferencial.',
    skills: [
      'Conexão e transformação com Power Query',
      'Modelagem de dados — relacionamentos e estrela',
      'DAX: medidas calculadas, KPIs, variáveis',
      'Funções de inteligência de tempo (YTD, MoM)',
      'Design de relatório para gestão',
      'Publicação e atualização automática',
    ],
    resources: ['Microsoft Learn', 'Guy in a Cube', 'SQLBI (DAX)', 'Alura Power BI'],
    ghLink: `${base}/projetos`,
  },
  {
    id: 'excel',
    name: 'Excel / Google Sheets',
    icon: '◉',
    level: 75,
    levelLabel: 'avançado',
    color: 'green',
    desc: 'Domínio sólido. Ponto de partida da análise operacional no setor público.',
    skills: [
      'Fórmulas avançadas (ÍNDICE, CORRESP, SOMASES)',
      'Power Query — importação e transformação',
      'Tabelas dinâmicas e gráficos',
      'Dashboards automatizados',
      'Validação de dados e controle de formulários',
      'VBA básico para automação',
    ],
    resources: ['ExcelJet', 'Planilhando', 'Microsoft Learn'],
    ghLink: `${base}/estudos`,
  },
  {
    id: 'estatistica',
    name: 'Estatística',
    icon: '◎',
    level: 40,
    levelLabel: 'em avanço',
    color: 'purple',
    desc: 'Base matemática para analytics. Foco em estatística descritiva e inferencial aplicada a dados operacionais.',
    skills: [
      'Medidas de tendência central e dispersão',
      'Distribuições de probabilidade',
      'Testes de hipótese',
      'Correlação e regressão linear',
      'Análise exploratória de dados (EDA)',
      'Visualização estatística',
    ],
    resources: ['StatQuest', 'Khan Academy', 'DataCamp Statistics', 'Think Stats'],
    ghLink: `${base}/estudos`,
  },
  {
    id: 'ml',
    name: 'Machine Learning',
    icon: '◇',
    level: 25,
    levelLabel: 'iniciando',
    color: 'purple',
    desc: 'Aprendizado supervisionado e forecasting aplicados a operações. Foco em aplicação prática, não teoria pura.',
    skills: [
      'Conceitos fundamentais de ML',
      'Scikit-learn: treino, teste, validação',
      'Regressão linear e logística',
      'Árvores de decisão',
      'Séries temporais com Prophet',
      'Métricas de avaliação de modelos',
    ],
    resources: ['Hands-On ML (Aurélien Géron)', 'Fast.ai', 'DataCamp ML track', 'Kaggle Learn'],
    ghLink: `${base}/projetos`,
  },
  {
    id: 'automacao',
    name: 'Automação',
    icon: '⌥',
    level: 40,
    levelLabel: 'em avanço',
    color: 'blue',
    desc: 'Eliminar tarefas manuais repetitivas. Python e Power Automate são as principais ferramentas.',
    skills: [
      'Scripts Python para automação de relatórios',
      'Manipulação de arquivos Excel/CSV com Python',
      'Power Automate — fluxos básicos e intermediários',
      'Agendamento com cron e Task Scheduler',
      'Envio automático de e-mails com dados',
      'Integração entre ferramentas via API',
    ],
    resources: ['Automate the Boring Stuff', 'Microsoft Power Automate Docs', 'Alura Automação'],
    ghLink: `${base}/projetos`,
  },
  {
    id: 'engdados',
    name: 'Engenharia de Dados',
    icon: '◬',
    level: 20,
    levelLabel: 'iniciando',
    color: 'purple',
    desc: 'Pipeline de dados do começo ao fim. Próximo passo natural após dominar SQL e Python.',
    skills: [
      'Conceitos de ETL e ELT',
      'dbt básico — modelos e transformações',
      'Arquitetura de data warehouse',
      'Formatos de dados (Parquet, JSON, CSV)',
      'Orquestração básica (Airflow conceitos)',
      'Qualidade e governança de dados',
    ],
    resources: ['Fundamentals of Data Engineering', 'dbt Learn', 'DataTalks.Club'],
    ghLink: `${base}/estudos`,
  },
  {
    id: 'ia',
    name: 'IA Aplicada',
    icon: '◯',
    level: 30,
    levelLabel: 'explorando',
    color: 'blue',
    desc: 'LLMs como ferramenta para analytics e gestão. Foco em aplicações práticas, não em treinar modelos.',
    skills: [
      'Prompt engineering para análise de dados',
      'LLMs + dados estruturados (RAG básico)',
      'Copilot e assistentes de código',
      'Automação com agentes LLM',
      'API Anthropic / OpenAI básico',
      'IA generativa aplicada a relatórios',
    ],
    resources: ['Anthropic Docs', 'LangChain Docs', 'DeepLearning.AI', 'fast.ai Practical Deep Learning'],
    ghLink: `${base}/projetos`,
  },
];

const colorMap: Record<string, string> = {
  blue: 'var(--accent)',
  purple: 'var(--accent-2)',
  green: '#4ade80',
};
---

<Base
  title="Stacks — Odiney Souza"
  description="Stacks técnicas em estudo: SQL, Python, Power BI, Estatística, ML, Automação, Engenharia de Dados e IA Aplicada."
>
  <section class="section">
    <div class="container">
      <a href={`${base}/`} class="back-link label">← Home</a>

      <div class="page-header">
        <p class="label" style="margin-bottom:.75rem; margin-top:1.5rem">stacks</p>
        <h1>Ferramentas e tecnologias</h1>
        <p class="page-desc">
          Cada stack em estudo aplicada a problemas reais. Os níveis refletem onde estou agora — não
          onde pretendo chegar.
        </p>
      </div>

      <!-- OVERVIEW BAR -->
      <div class="overview-grid">
        {stacks.map(s => (
          <div class="overview-item">
            <div class="overview-header">
              <span class="overview-name" style={`color:${colorMap[s.color] || 'var(--accent)'}`}>
                {s.icon} {s.name}
              </span>
              <span class="label">{s.level}%</span>
            </div>
            <div class="progress-bar">
              <div
                class="progress-bar-fill"
                style={`width:${s.level}%; background:${colorMap[s.color] || 'var(--accent)'}`}
              />
            </div>
          </div>
        ))}
      </div>

      <hr class="divider" style="margin-block:3rem" />

      <!-- STACKS DETAIL -->
      <div class="stacks-grid">
        {stacks.map(s => (
          <div class="stack-card card" id={s.id}>
            <div class="stack-top">
              <div class="stack-title-row">
                <span class="stack-icon" style={`color:${colorMap[s.color] || 'var(--accent)'}`}>
                  {s.icon}
                </span>
                <h2 class="stack-name">{s.name}</h2>
                <span class={`badge${s.color === 'purple' ? ' purple' : ''}`}>
                  {s.levelLabel}
                </span>
              </div>
              <div class="progress-bar" style="margin-top:.75rem">
                <div
                  class="progress-bar-fill"
                  style={`width:${s.level}%; background:${colorMap[s.color] || 'var(--accent)'}`}
                />
              </div>
              <p class="stack-desc">{s.desc}</p>
            </div>

            <div class="stack-skills">
              <p class="label" style="margin-bottom:.5rem">o que estudo</p>
              <ul class="skills-list">
                {s.skills.map(sk => <li>{sk}</li>)}
              </ul>
            </div>

            <div class="stack-resources">
              <p class="label" style="margin-bottom:.5rem">fontes</p>
              <div class="resources-list">
                {s.resources.map(r => <span class="resource-tag">{r}</span>)}
              </div>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>
</Base>

<style>
.back-link {
  color: var(--text-muted);
  text-decoration: none;
  transition: color .15s;
}
.back-link:hover { color: var(--text); }

.page-header { margin-bottom: 2rem; }

.page-desc {
  color: var(--text-muted);
  max-width: 560px;
  line-height: 1.75;
  margin-top: .75rem;
}

/* Overview */
.overview-grid {
  display: grid;
  grid-template-columns: repeat(auto-fill, minmax(240px, 1fr));
  gap: .75rem 1.5rem;
  margin-bottom: .5rem;
}

.overview-item {}

.overview-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: .35rem;
}

.overview-name {
  font-family: var(--font-mono);
  font-size: .8rem;
  font-weight: 500;
}

/* Stacks grid */
.stacks-grid {
  display: grid;
  grid-template-columns: repeat(auto-fill, minmax(320px, 1fr));
  gap: 1rem;
}

.stack-card {
  display: flex;
  flex-direction: column;
  gap: 1rem;
}

.stack-top {}

.stack-title-row {
  display: flex;
  align-items: center;
  gap: .6rem;
  flex-wrap: wrap;
}

.stack-icon { font-size: 1rem; }

.stack-name {
  font-size: 1rem;
  font-weight: 500;
  flex: 1;
}

.stack-desc {
  font-size: .875rem;
  color: var(--text-muted);
  line-height: 1.6;
  margin-top: .75rem;
}

/* Skills */
.stack-skills {}

.skills-list {
  list-style: none;
  display: flex;
  flex-direction: column;
  gap: .3rem;
}

.skills-list li {
  font-size: .8rem;
  color: var(--text-muted);
  padding-left: .75rem;
  position: relative;
  line-height: 1.4;
}

.skills-list li::before {
  content: '·';
  position: absolute;
  left: 0;
  color: var(--accent);
}

/* Resources */
.stack-resources { margin-top: auto; }

.resources-list {
  display: flex;
  flex-wrap: wrap;
  gap: .35rem;
}

.resource-tag {
  font-family: var(--font-mono);
  font-size: .7rem;
  padding: .2rem .5rem;
  border-radius: 4px;
  background: var(--bg);
  border: 1px solid var(--border);
  color: var(--text-muted);
}
</style>
